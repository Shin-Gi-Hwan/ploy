# ──────────────────────────────────────────────────────────────────────────────
# .env.example — TEMPLATE for new developers
#
# Copy this file and fill in real values:
#   cp .env.example .env.dev    # for local development
#   cp .env.example .env.prod   # for production (fill in on server)
#
# Both .env.dev and .env.prod are git-ignored. Never commit real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── Spring profile ────────────────────────────────────────────────────────────
# Options: dev | prod
SPRING_PROFILES_ACTIVE=dev

# ── Database ──────────────────────────────────────────────────────────────────
# For Docker Compose: DB_HOST is overridden to the service name ("mysql")
# For native IntelliJ dev: leave as localhost
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ploy
DB_USERNAME=ploy
DB_PASSWORD=your_db_password

# MySQL root password (Docker only)
MYSQL_ROOT_PASSWORD=your_root_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Production: generate with `openssl rand -base64 64`
JWT_SECRET=replace-with-a-long-random-secret-at-least-256-bits
JWT_EXPIRY_MS=604800000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=you@yourdomain.com

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_admin_password

# ── URLs ──────────────────────────────────────────────────────────────────────
# Dev: http://localhost:5173
# Prod: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ── OAuth2 Social Login ────────────────────────────────────────────────────────
# Redirect base URL (registered in each OAuth provider's allowed redirect URIs)
# Dev: http://localhost:5173  |  Prod: https://yourdomain.com
OAUTH2_REDIRECT_BASE_URL=http://localhost:5173

# Google → https://console.cloud.google.com
# Authorized redirect URI: {OAUTH2_REDIRECT_BASE_URL}/api/auth/oauth2/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Naver → https://developers.naver.com
# Authorized redirect URI: {OAUTH2_REDIRECT_BASE_URL}/api/auth/oauth2/callback/naver
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Kakao → https://developers.kakao.com
# Authorized redirect URI: {OAUTH2_REDIRECT_BASE_URL}/api/auth/oauth2/callback/kakao
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret   # Kakao는 선택사항

# ── Storage ───────────────────────────────────────────────────────────────────
# Local filesystem path for uploaded deliverables
STORAGE_PATH=/data/uploads

# ── Future: Redis ─────────────────────────────────────────────────────────────
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ── Future: RabbitMQ ──────────────────────────────────────────────────────────
# RABBITMQ_HOST=rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=ploy
# RABBITMQ_PASSWORD=your_rabbitmq_password

# ── Future: MinIO ─────────────────────────────────────────────────────────────
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_BUCKET=ploy-deliverables